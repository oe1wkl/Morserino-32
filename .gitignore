.DS_Store

# Finder / iCloud duplicate-copy artifacts of the .ino sketch, e.g.
# "m32_v6.ino 2.cpp" — these cause "multiple definition" link errors.
# (A pre-build hook, scripts/clean_ino_dupes.py, also strips them.)
*.ino [0-9]*.cpp

# Audio-accessibility (V9.0): the TTS clips under Software/src/data/voice/ ARE
# committed. They look like build artifacts but are not reproducible from a clean
# clone -- the Piper voice model below is gitignored -- so ignoring them left the
# accessibility edition silently mute for anyone else who built it. Committing
# them also means a builder who just wants to flash needs no TTS toolchain, only
# `-t uploadfs`. Filenames are md5(spoken text), so clips are immutable and new
# UI text only ever adds files; `generate_audio.sh --prune` clears orphans.

# Audio-accessibility tooling: Piper venv + voice models (machine-specific / large)
Software/tools/audio-accessibility/.venv/
Software/tools/audio-accessibility/models/
